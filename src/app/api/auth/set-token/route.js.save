import { NextResponse } from 'next/server';
import jwt from 'jsonwebtoken';
import pool from '@/lib/db';
import { generateToken } from '@/lib/auth';

// ✅ IMPORTANT: These secrets must match lib/auth.js
const BRIDGE_SECRET = process.env.BRIDGE_SECRET || 'my-super-secret-key-123';
const JWT_SECRET = process.env.JWT_SECRET || 'my-super-secret-key-123';

export async function POST(request) {
  try {
    const body = await request.json();
    console.log('📥 Set-token request received:', {
      hasToken: !!body.token,
      hasUsername: !!body.username,
      hasEmail: !!body.email,
      body: body
    });

    // ── FLOW 2: Direct postMessage data (username, email, guestUserId, name) ──
    // External iframe parent sends raw user data — no JWT needed
    if (!body.token && (body.username || body.email)) {
      console.log('🔄 Using DIRECT USER DATA flow');
      const { username, email, guestUserId, name } = body;

      if (!username || !email) {
        return NextResponse.json({ success: false, error: 'username and email are required' }, { status: 400 });
      }

      const external_user_id = guestUserId || username;
      const displayName = name || username;

      // Find or create user
      console.log('🔍 Checking database for user:', email);
      const [existing] = await pool.query('SELECT * FROM users WHERE email = ?', [email]);
      let user;

      if (existing.length > 0) {
        console.log('👤 Existing user found:', existing[0].id);
        user = existing[0];
        // Keep external_user_id and name in sync
        await pool.query(
          'UPDATE users SET external_user_id = ?, username = ? WHERE id = ?',
          [external_user_id, displayName, user.id]
        );
        user.username = displayName;
        user.external_user_id = external_user_id;
        console.log('✅ User updated');
      } else {
        console.log('➕ Creating new user:', { displayName, email, external_user_id });
        const [result] = await pool.query(
          `INSERT INTO users (username, email, password, role_id, external_user_id)
           VALUES (?, ?, 'EXTERNAL_USER', 3, ?)`,
          [displayName, email, external_user_id]
        );
        console.log('✅ User created with ID:', result.insertId);
        const [newUser] = await pool.query('SELECT * FROM users WHERE id = ?', [result.insertId]);
        user = newUser[0];
      }

      const newToken = generateToken(user);
      console.log('🔑 Generated new token for user:', user.id);

      const response = NextResponse.json({
        success: true,
        user: {
          id: user.id,
          username: user.username,
          email: user.email,
          role_id: user.role_id,
          external_user_id: user.external_user_id,
        },
        token: newToken,
      });


const cookieSettings = {
  httpOnly: true,
  secure: false,
  sameSite: 'lax',  // ✅ 'none' → 'lax' karo (HTTP ke liye)
  maxAge: 60 * 60 * 24 * 7,
  path: '/',
} as const;

response.cookies.set('token', newToken, cookieSettings);



      console.log('✅ Direct postMessage auth success for:', email);
      console.log('🍪 Cookie set with sameSite=', cookieSettings.sameSite, ', secure=', cookieSettings.secure);
      return response;
    }

    // ── FLOW 1: Existing JWT bridge-token flow ──
    console.log('🔄 Using JWT TOKEN flow');
    const { token } = body;

    if (!token) {
      return NextResponse.json({ success: false, error: 'Token or user data missing' }, { status: 400 });
    }

    console.log('🔐 Attempting to verify JWT token...');
    console.log('Token preview:', token.substring(0, 50) + '...');

    // 3001 ka JWT verify karo - try multiple secrets
    let decoded;
    const secretsToTry = [
      BRIDGE_SECRET,
      JWT_SECRET,
      'my-3001-jwt-secret',
      'my-super-secret-key-123',
      'your-secret-key-change-this'
    ];

    let verificationError;
    for (const secret of secretsToTry) {
      try {
        decoded = jwt.verify(token, secret);
        console.log(`✅ Token verified successfully with secret: ${secret.substring(0, 10)}...`);
        break;
      } catch (err) {
        verificationError = err;
        console.log(`❌ Failed with secret ${secret.substring(0, 10)}...:`, err.message);
        continue;
      }
    }

    if (!decoded) {
      console.error('Token verification failed with all secrets');
      console.error('Last error:', verificationError.message);
      console.error('Token received:', token);
      return NextResponse.json({
        success: false,
        error: 'Invalid token',
        details: verificationError.message
      }, { status: 401 });
    }

    console.log('Decoded token:', decoded);

    // decoded mein se user details nikalo
    // (jo 3001 ne JWT mein store kiye the — id, email, username)
    // Handle both 'id' and 'userId' formats
    const external_user_id = decoded.id || decoded.userId;
    const email = decoded.email;
    const username = decoded.username;

    if (!external_user_id || !email || !username) {
      console.error('Missing required fields in token:', { external_user_id, email, username });
      return NextResponse.json({
        success: false,
        error: 'Invalid token structure'
      }, { status: 400 });
    }

    // 3000 ke DB mein user check karo
    console.log('🔍 Checking database for JWT user:', email, 'external_user_id:', external_user_id);

    // ✅ FIX: Check by both email AND external_user_id to find the correct user
    const [existingByEmail] = await pool.query(
      'SELECT * FROM users WHERE email = ?',
      [email]
    );

    const [existingByExternalId] = await pool.query(
      'SELECT * FROM users WHERE external_user_id = ?',
      [String(external_user_id)]
    );

    let user;

    // Priority: external_user_id match (most reliable)
    if (existingByExternalId.length > 0) {
      console.log('👤 User found by external_user_id:', existingByExternalId[0].id);
      user = existingByExternalId[0];

      // Update email/username if changed
      if (user.email !== email || user.username !== username) {
        await pool.query(
          'UPDATE users SET email = ?, username = ? WHERE id = ?',
          [email, username, user.id]
        );
        console.log('✅ User email/username updated');
        user.email = email;
        user.username = username;
      }
    }
    // Fallback: email match but no external_user_id yet
    else if (existingByEmail.length > 0) {
      console.log('👤 User found by email:', existingByEmail[0].id);
      user = existingByEmail[0];

      // Set the external_user_id for future logins
      await pool.query(
        'UPDATE users SET external_user_id = ?, username = ? WHERE id = ?',
        [String(external_user_id), username, user.id]
      );
      console.log('✅ User linked with external_user_id');
      user.external_user_id = String(external_user_id);
      user.username = username;
    }
    // Create new user
    else {
      console.log('➕ Creating new user from JWT:', { username, email, external_user_id });
      const [result] = await pool.query(
        `INSERT INTO users (username, email, password, role_id, external_user_id)
         VALUES (?, ?, 'EXTERNAL_USER', 3, ?)`,
        [username, email, String(external_user_id)]
      );
      console.log('✅ User created with ID:', result.insertId);

      const [newUser] = await pool.query(
        'SELECT * FROM users WHERE id = ?',
        [result.insertId]
      );
      user = newUser[0];
    }

    // 3000 ka apna token generate karo
    const newToken = generateToken(user);
    console.log('🔑 Generated new token for JWT user:', user.id);

    const response = NextResponse.json({
      success: true,
      user: {
        id: user.id,
        username: user.username,
        email: user.email,
        role_id: user.role_id,
        external_user_id: user.external_user_id,
      },
      token: newToken
    });

    // Cookie settings: sameSite='none' needs secure=true, otherwise use 'lax'
    const cookieSettings = {
      httpOnly: true,
      secure: false,  // ✅ Always true (required for sameSite=none)
      sameSite: 'lax',   // Allow cross-origin cookies
      maxAge: 60 * 60 * 24 * 7,
      path: '/',
    };


    response.cookies.set('token', newToken, cookieSettings);

    console.log('✅ JWT auth success for:', email);
    console.log('🍪 Cookie set with sameSite=', cookieSettings.sameSite, ', secure=', cookieSettings.secure);

    return response;
  } catch (error) {
    console.error('❌ Set token error:', error);
    console.error('Stack:', error.stack);
    return NextResponse.json({
      success: false,
      error: 'Internal server error: ' + error.message
    }, { status: 500 });
  }
}
